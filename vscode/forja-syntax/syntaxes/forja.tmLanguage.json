{
  "$schema": "https://raw.githubusercontent.com/martinring/tmlanguage/master/tmlanguage.json",
  "name": "Forja",
  "scopeName": "source.forja",
  "fileTypes": [".fa"],
  "patterns": [
    { "include": "#comments" },
    { "include": "#strings" },
    { "include": "#keywords" },
    { "include": "#types" },
    { "include": "#numbers" },
    { "include": "#builtins" },
    { "include": "#operators" },
    { "include": "#identifiers" }
  ],
  "repository": {
    "comments": {
      "patterns": [
        {
          "name": "comment.line.double-slash.forja",
          "match": "//.*$"
        },
        {
          "name": "comment.block.forja",
          "begin": "/\\*",
          "end": "\\*/"
        }
      ]
    },
    "strings": {
      "name": "string.quoted.double.forja",
      "begin": "\"",
      "end": "\"",
      "patterns": [
        { "name": "constant.character.escape.forja", "match": "\\\\[nrt\"\\\\]" }
      ]
    },
    "keywords": {
      "name": "keyword.control.forja",
      "match": "\\b(importar|variable|constante|mut|si|sino|mientras|para|repetir|funcion|retornar|clase|constructor|nuevo|este|prestado|coincidir|caso|tipo)\\b"
    },
    "types": {
      "name": "storage.type.forja",
      "match": "\\b(Entero|Decimal|Texto|Booleano|Nulo)\\b"
    },
    "numbers": {
      "patterns": [
        { "name": "constant.numeric.decimal.forja", "match": "\\b\\d+\\.\\d+\\b" },
        { "name": "constant.numeric.integer.forja", "match": "\\b\\d+\\b" }
      ]
    },
    "builtins": {
      "name": "support.function.forja",
      "match": "\\b(escribir|leer)\\b"
    },
    "literals": {
      "name": "constant.language.forja",
      "match": "\\b(verdadero|falso|nulo)\\b"
    },
    "operators": {
      "name": "keyword.operator.forja",
      "match": "(\\+|-|\\*|/|==|!=|>=|<=|>|<|&&|\\|\\||!)"
    },
    "identifiers": {
      "name": "variable.other.forja",
      "match": "\\b[a-zA-Z_][a-zA-Z0-9_]*\\b"
    }
  }
}
