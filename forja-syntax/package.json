          "when": "resourceLangId == forja"
        },
        {
          "command": "forja.runDebug",
          "when": "resourceLangId == forja"
        },
        {
          "command": "forja.runGUI",
          "when": "resourceLangId == forja"
        },
        {
          "command": "forja.runRepl",
          "when": "resourceLangId == forja"
        },
        {
          "command": "forja.build",
          "when": "resourceLangId == forja"
        },
        {
          "command": "forja.buildASM",
          "when": "resourceLangId == forja"
        },
        {
          "command": "forja.buildAndroid",
          "when": "resourceLangId == forja"
        },
        {
