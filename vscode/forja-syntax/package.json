{
  "name": "forja-syntax",
  "displayName": "Forja Language",
  "description": "Soporte para el lenguaje Forja — sintaxis, LSP, formateo y diagnósticos",
  "version": "0.4.0",
  "publisher": "forja-lang",
  "license": "MIT",
  "engines": {
    "vscode": "^1.60.0"
  },
  "categories": [
    "Programming Languages",
    "Formatters",
    "Linters"
  ],
  "activationEvents": [
    "onLanguage:forja"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "languages": [{
      "id": "forja",
      "aliases": ["Forja", "forja", "fa"],
      "extensions": [".fa"],
      "configuration": "./language-configuration.json"
    }],
    "grammars": [{
      "language": "forja",
      "scopeName": "source.forja",
      "path": "./syntaxes/forja.tmLanguage.json"
    }],
    "commands": [{
      "command": "forja.run",
      "title": "Forja: Ejecutar archivo"
    }]
  },
  "scripts": {
    "compile": "tsc -p ./tsconfig.json",
    "watch": "tsc -watch -p ./tsconfig.json"
  },
  "devDependencies": {
    "@types/vscode": "^1.60.0",
    "typescript": "^5.0.0"
  },
  "dependencies": {
    "vscode-languageclient": "^8.0.0"
  }
}
