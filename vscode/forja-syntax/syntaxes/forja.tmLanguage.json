{
  "$schema": "https://raw.githubusercontent.com/martinring/tmlanguage/master/tmlanguage.json",
  "name": "Forja",
  "scopeName": "source.forja",
  "fileTypes": [".fa"],
  "patterns": [
    { "include": "#comments" },
    { "include": "#doc-comments" },
    { "include": "#strings" },
    { "include": "#characters" },
    { "include": "#numbers" },
    { "include": "#literals" },
    { "include": "#keywords" },
    { "include": "#types" },
    { "include": "#builtins" },
    { "include": "#attributes" },
    { "include": "#function-definition" },
    { "include": "#class-definition" },
    { "include": "#new-instance" },
    { "include": "#type-definition" },
    { "include": "#function-call" },
    { "include": "#member-access" },
    { "include": "#type-annotation" },
    { "include": "#uppercase-identifier" },
    { "include": "#operators" },
    { "include": "#punctuation" },
    { "include": "#identifiers" }
  ],
  "repository": {
    "comments": {
      "patterns": [
        {
          "name": "comment.line.double-slash.forja",
          "match": "//.*$"
        },
        {
          "name": "comment.block.forja",
          "begin": "/\\*",
          "end": "\\*/"
        }
      ]
    },

    "doc-comments": {
      "patterns": [
        {
          "name": "comment.line.documentation.forja",
          "match": "///.*$"
        }
      ]
    },

    "strings": {
      "name": "string.quoted.double.forja",
      "begin": "\"",
      "end": "\"",
      "patterns": [
        {
          "name": "constant.character.escape.forja",
          "match": "\\\\(n|t|r|\"|\\\\|')"
        }
      ]
    },

    "characters": {
      "name": "constant.character.forja",
      "begin": "'",
      "end": "'",
      "patterns": [
        {
          "name": "constant.character.escape.forja",
          "match": "\\\\(n|t|r|\\\\|')"
        }
      ]
    },

    "keywords": {
      "patterns": [
        {
          "name": "keyword.control.forja",
          "match": "\\b(importar|variable|var|constante|const|mut|si|sino|mientras|para|repetir|funcion|fun|retornar|clase|constructor|nuevo|este|prestado|tipo|coincidir|caso|BD|externo|externa|hilo|canal|enviar|recibir|unir|trait|implementa|donde|seleccionar|tiempo|otro|no)\\b"
        }
      ]
    },

    "types": {
      "name": "storage.type.forja",
      "match": "\\b(Entero|Decimal|Texto|Booleano|Nulo)\\b"
    },

    "literals": {
      "name": "constant.language.forja",
      "match": "\\b(verdadero|falso|nulo)\\b"
    },

    "numbers": {
      "patterns": [
        { "name": "constant.numeric.decimal.forja", "match": "\\b\\d+\\.\\d+\\b" },
        { "name": "constant.numeric.integer.forja", "match": "\\b\\d+\\b" }
      ]
    },

    "builtins": {
      "name": "support.function.forja",
      "match": "\\b(escribir|leer|asegurar|longitud|aleatorio|redondear|potencia|raiz|maximo|minimo|concatenar|insertar|eliminar|contiene|claves|valores|tamaño|a_caracter|a_texto|a_entero|a_decimal|es_entero|es_texto|es_decimal|es_booleano|es_lista|es_mapa|es_nulo|es_arreglo|tiempo_actual|esperar|abrir_archivo|leer_archivo|escribir_archivo|crear_directorio|existe_archivo|conectar|consultar|ejecutar|cerrar|transaccion|guardar)\\b"
    },

    "attributes": {
      "patterns": [
        {
          "name": "keyword.operator.attribute.forja",
          "match": "@"
        },
        {
          "name": "entity.name.tag.forja",
          "match": "\\b(test|derive)\\b"
        }
      ]
    },

    "function-definition": {
      "match": "\\b(funcion|fun)\\s+([a-zA-Z_][a-zA-Z0-9_]*)\\b",
      "captures": {
        "1": { "name": "keyword.control.forja" },
        "2": { "name": "entity.name.function.forja" }
      }
    },

    "class-definition": {
      "match": "\\b(clase)\\s+([A-Z][a-zA-Z0-9_]*)\\b",
      "captures": {
        "1": { "name": "keyword.control.forja" },
        "2": { "name": "entity.name.class.forja" }
      }
    },

    "new-instance": {
      "match": "\\b(nuevo)\\s+([A-Z][a-zA-Z0-9_]*)\\b",
      "captures": {
        "1": { "name": "keyword.control.forja" },
        "2": { "name": "entity.name.class.forja" }
      }
    },

    "type-definition": {
      "match": "\\b(tipo)\\s+([A-Z][a-zA-Z0-9_]*)\\b",
      "captures": {
        "1": { "name": "keyword.control.forja" },
        "2": { "name": "entity.name.class.forja" }
      }
    },

    "function-call": {
      "match": "\\b([a-z_][a-zA-Z0-9_]*)\\s*(?=\\()",
      "name": "entity.name.function.forja"
    },

    "member-access": {
      "match": "(\\.)\\s*([a-zA-Z_][a-zA-Z0-9_]*)",
      "captures": {
        "1": { "name": "punctuation.dot.forja" },
        "2": { "name": "variable.other.property.forja" }
      }
    },

    "type-annotation": {
      "match": "(:)\\s*([A-Z][a-zA-Z0-9_]*)",
      "captures": {
        "1": { "name": "punctuation.colon.forja" },
        "2": { "name": "storage.type.forja" }
      }
    },

    "uppercase-identifier": {
      "name": "support.class.forja",
      "match": "\\b[A-Z][a-zA-Z0-9_]*\\b"
    },

    "operators": {
      "name": "keyword.operator.forja",
      "match": "\\+\\+|--|==|!=|>=|<=|\\+=|-=|\\*=|/=|%=|&&|\\|\\||->|::|\\.\\.\\.|%|\\||&|\\+|-|\\*|/|>|<|!|="
    },

    "punctuation": {
      "patterns": [
        { "name": "punctuation.semicolon.forja", "match": ";" },
        { "name": "punctuation.comma.forja", "match": "," },
        { "name": "punctuation.colon.forja", "match": ":" },
        { "name": "punctuation.dot.forja", "match": "\\." },
        { "name": "punctuation.parenthesis.forja", "match": "[\\(\\)]" },
        { "name": "punctuation.brace.forja", "match": "[\\{\\}]" },
        { "name": "punctuation.bracket.forja", "match": "[\\[\\]]" },
        { "name": "punctuation.question.forja", "match": "\\?" },
        { "name": "punctuation.at.forja", "match": "@" }
      ]
    },

    "identifiers": {
      "name": "variable.other.forja",
      "match": "\\b[a-z_][a-zA-Z0-9_]*\\b"
    }
  }
}
