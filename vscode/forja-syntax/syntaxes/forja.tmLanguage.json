{
  "$schema": "https://raw.githubusercontent.com/martinring/tmlanguage/master/tmlanguage.json",
  "name": "Forja",
  "scopeName": "source.forja",
  "fileTypes": [".fa"],
  "patterns": [
    { "include": "#comments" },
    { "include": "#strings" },
    { "include": "#keywords" },
    { "include": "#types" },
    { "include": "#literals" },
    { "include": "#numbers" },
    { "include": "#builtins" },
    { "include": "#function-definition" },
    { "include": "#class-definition" },
    { "include": "#new-instance" },
    { "include": "#type-definition" },
    { "include": "#function-call" },
    { "include": "#member-access" },
    { "include": "#type-annotation" },
    { "include": "#uppercase-identifier" },
    { "include": "#operators" },
    { "include": "#punctuation" },
    { "include": "#identifiers" }
  ],
  "repository": {
    "comments": {
      "patterns": [
        {
          "name": "comment.line.double-slash.forja",
          "match": "//.*$"
        },
        {
          "name": "comment.block.forja",
          "begin": "/\\*",
          "end": "\\*/"
        }
      ]
    },

    "strings": {
      "name": "string.quoted.double.forja",
      "begin": "\"",
      "end": "\"",
      "patterns": [
        {
          "name": "constant.character.escape.forja",
          "match": "\\\\[nrt\"\\\\]"
        }
      ]
    },

    "keywords": {
      "patterns": [
        {
          "name": "keyword.control.forja",
          "match": "\\b(importar|variable|var|constante|const|mut|si|sino|mientras|para|repetir|funcion|retornar|clase|constructor|nuevo|este|prestado|prestado\\s+mut|tipo|coincidir|caso|BD)\\b"
        }
      ]
    },

    "types": {
      "name": "storage.type.forja",
      "match": "\\b(Entero|Decimal|Texto|Booleano|Nulo)\\b"
    },

    "literals": {
      "name": "constant.language.forja",
      "match": "\\b(verdadero|falso|nulo)\\b"
    },

    "numbers": {
      "patterns": [
        { "name": "constant.numeric.decimal.forja", "match": "\\b\\d+\\.\\d+\\b" },
        { "name": "constant.numeric.integer.forja", "match": "\\b\\d+\\b" }
      ]
    },

    "builtins": {
      "name": "support.function.forja",
      "match": "\\b(escribir|leer)\\b"
    },

    "function-definition": {
      "match": "\\b(funcion)\\s+([a-zA-Z_][a-zA-Z0-9_]*)\\b",
      "captures": {
        "1": { "name": "keyword.control.forja" },
        "2": { "name": "entity.name.function.forja" }
      }
    },

    "class-definition": {
      "match": "\\b(clase)\\s+([A-Z][a-zA-Z0-9_]*)\\b",
      "captures": {
        "1": { "name": "keyword.control.forja" },
        "2": { "name": "entity.name.class.forja" }
      }
    },

    "new-instance": {
      "match": "\\b(nuevo)\\s+([A-Z][a-zA-Z0-9_]*)\\b",
      "captures": {
        "1": { "name": "keyword.control.forja" },
        "2": { "name": "entity.name.class.forja" }
      }
    },

    "type-definition": {
      "match": "\\b(tipo)\\s+([A-Z][a-zA-Z0-9_]*)\\b",
      "captures": {
        "1": { "name": "keyword.control.forja" },
        "2": { "name": "entity.name.class.forja" }
      }
    },

    "function-call": {
      "match": "\\b([a-z_][a-zA-Z0-9_]*)\\s*(?=\\()",
      "name": "entity.name.function.forja"
    },

    "member-access": {
      "match": "(\\.)\\s*([a-zA-Z_][a-zA-Z0-9_]*)",
      "captures": {
        "1": { "name": "punctuation.dot.forja" },
        "2": { "name": "variable.other.property.forja" }
      }
    },

    "type-annotation": {
      "match": "(:)\\s*([A-Z][a-zA-Z0-9_]*)",
      "captures": {
        "1": { "name": "punctuation.colon.forja" },
        "2": { "name": "storage.type.forja" }
      }
    },

    "uppercase-identifier": {
      "name": "support.class.forja",
      "match": "\\b[A-Z][a-zA-Z0-9_]*\\b"
    },

    "operators": {
      "name": "keyword.operator.forja",
      "match": "(\\+|-|\\*|/|==|!=|>=|<=|>|<|&&|\\|\\||!|=|&)"
    },

    "punctuation": {
      "patterns": [
        { "name": "punctuation.semicolon.forja", "match": ";" },
        { "name": "punctuation.comma.forja", "match": "," },
        { "name": "punctuation.colon.forja", "match": ":" },
        { "name": "punctuation.dot.forja", "match": "\\." },
        { "name": "punctuation.parenthesis.forja", "match": "[\\(\\)]" },
        { "name": "punctuation.brace.forja", "match": "[\\{\\}]" },
        { "name": "punctuation.bracket.forja", "match": "[\\[\\]]" }
      ]
    },

    "identifiers": {
      "name": "variable.other.forja",
      "match": "\\b[a-z_][a-zA-Z0-9_]*\\b"
    }
  }
}
