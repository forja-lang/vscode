{
  "name": "forja-syntax",
  "displayName": "Forja (fa)",
  "description": "Soporte completo para el lenguaje Forja — sintaxis, LSP, compilación, debug, toolchain",
  "version": "0.4.0",
  "publisher": "lococoi",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/lococoi/forja.git"
  },
  "engines": {
    "vscode": "^1.60.0"
  },
  "categories": [
    "Programming Languages",
    "Formatters",
    "Linters",
    "Debuggers",
    "Notebooks",
    "Education",
    "Other"
  ],
  "activationEvents": [
    "onLanguage:forja",
    "onCommand:forja.run",
    "onCommand:forja.runFast",
    "onCommand:forja.runJIT",
    "onCommand:forja.runAOT",
    "onCommand:forja.runDebug",
    "onCommand:forja.runGUI",
    "onCommand:forja.runRepl",
    "onCommand:forja.build",
    "onCommand:forja.buildASM",
    "onCommand:forja.buildAndroid",
    "onCommand:forja.buildWASM",
    "onCommand:forja.test",
    "onCommand:forja.bench",
    "onCommand:forja.fmt",
    "onCommand:forja.doc",
    "onCommand:forja.diagram",
    "onCommand:forja.transpile",
    "onCommand:forja.hotReload",
    "onCommand:forja.hotRestart",
    "onCommand:forja.newProject",
    "onCommand:forja.selectVM",
    "onCommand:forja.selectTarget",
    "onCommand:forja.showOutput",
    "onCommand:forja.installToolchain",
    "onCommand:forja.toggleHotReload",
    "onCommand:forja.openTutorial",
    "onCommand:forja.openWasmPlayground",
    "onCommand:forja.openDiagram",
    "onCommand:forja.buildAndroid.arm64",
    "onCommand:forja.buildAndroid.x86_64",
    "onCommand:forja.buildAndroid.all",
    "onCommand:forja.checkAndroidNDK",
    "onCommand:forja.deployAndroid",
    "onDebug",
    "onDebugInitialConfigurations",
    "onCommand:forja.showAST",
    "onCommand:forja.showBytecode",
    "onCommand:forja.openStdlib",
    "onCommand:forja.openFile",
    "onCommand:forja.revealLine",
    "onView:forja.repl",
    "onView:forja.tutorial",
    "onView:forja.wasmPlayground",
    "onView:forja.diagram",
    "onView:forja.projectOutline",
    "onView:forja.examples",
    "onView:forja.stdlib"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "languages": [
      {
        "id": "forja",
        "aliases": [
          "Forja",
          "forja",
          "fa"
        ],
        "extensions": [
          ".fa"
        ],
        "configuration": "./language-configuration.json"
      }
    ],
    "grammars": [
      {
        "language": "forja",
        "scopeName": "source.forja",
        "path": "./syntaxes/forja.tmLanguage.json"
      }
    ],
    "configurationDefaults": {
      "[forja]": {
        "editor.tokenColorCustomizations": {
          "textMateRules": [
            {
              "scope": "variable.other.readwrite.forja",
              "settings": { "foreground": "#06b6d4" }
            },
            {
              "scope": "string.quoted.double.forja",
              "settings": { "foreground": "#a6e3a1" }
            },
            {
              "scope": "constant.character.forja",
              "settings": { "foreground": "#a6e3a1" }
            },
            {
              "scope": "keyword.control.self.forja",
              "settings": { "foreground": "#d8b4fe" }
            },
            {
              "scope": "keyword.control.forja",
              "settings": { "foreground": "#cba6f7" }
            },
            {
              "scope": "keyword.operator.forja",
              "settings": { "foreground": "#89dceb" }
            },
            {
              "scope": "storage.type.forja",
              "settings": { "foreground": "#74c7ec" }
            },
            {
              "scope": "support.function.forja, entity.name.function.forja",
              "settings": { "foreground": "#89b4fa" }
            },
            {
              "scope": "constant.numeric.decimal.forja, constant.numeric.integer.forja",
              "settings": { "foreground": "#fab387" }
            },
            {
              "scope": "constant.language.forja",
              "settings": { "foreground": "#f9e2af" }
            },
            {
              "scope": "support.class.forja",
              "settings": { "foreground": "#74c7ec" }
            },
            {
              "scope": "comment",
              "settings": { "foreground": "#6c7086" }
            },
            {
              "scope": "punctuation",
              "settings": { "foreground": "#bac2de" }
            }
          ]
        }
      }
    },
    "viewsContainers": {
      "activitybar": [
        {
          "id": "forja-sidebar",
          "title": "Forja",
          "icon": "$(zap)"
        }
      ]
    },
    "views": {
      "forja-sidebar": [
        {
          "type": "tree",
          "id": "forja.projectOutline",
          "name": "Estructura",
          "icon": "$(symbol-misc)"
        },
        {
          "type": "tree",
          "id": "forja.examples",
          "name": "Ejemplos Forja",
          "icon": "$(book)"
        },
        {
          "type": "tree",
          "id": "forja.stdlib",
          "name": "Explorador de Biblioteca",
          "icon": "$(library)"
        },
        {
          "type": "webview",
          "id": "forja.repl",
          "name": "VM",
          "icon": "$(terminal)"
        },
        {
          "type": "webview",
          "id": "forja.diagram",
          "name": "Diagramas",
          "icon": "$(graph)"
        },
        {
          "type": "webview",
          "id": "forja.tutorial",
          "name": "Tutorial",
          "icon": "$(book)"
        },
        {
          "type": "webview",
          "id": "forja.wasmPlayground",
          "name": "Laboratorio WASM",
          "icon": "$(globe)"
        }
      ],
      "panel": []
    },
    "debuggers": [
      {
        "type": "forja",
        "label": "Forja Debug",
        "languages": [
          "forja"
        ],
        "configurationAttributes": {
          "launch": {
            "required": [
              "program"
            ],
            "properties": {
              "program": {
                "type": "string",
                "description": "Ruta al archivo .fa a depurar",
                "default": "${file}"
              }
            }
          }
        },
        "initialConfigurations": [
          {
            "type": "forja",
            "request": "launch",
            "name": "Forja: Debug archivo activo",
            "program": "${file}"
          }
        ],
        "configurationSnippets": [
          {
            "label": "Forja: Debug archivo activo",
            "description": "Depurar el archivo .fa activo",
            "body": {
              "type": "forja",
              "request": "launch",
              "name": "Forja: Debug archivo activo",
              "program": "^\"\\${file}\""
            }
          }
        ]
      }
    ],
    "commands": [
      {
        "command": "forja.run",
        "title": "Forja: Ejecutar archivo (VM clasica)",
        "icon": "$(play)"
      },
      {
        "command": "forja.runFast",
        "title": "Forja: Ejecutar con FastVM",
        "icon": "$(zap)"
      },
      {
        "command": "forja.runJIT",
        "title": "Forja: Ejecutar con JIT (nativo con reemplazo)",
        "icon": "$(rocket)"
      },
      {
        "command": "forja.runAOT",
        "title": "Forja: Compilar AOT y ejecutar",
        "icon": "$(tools)"
      },
      {
        "command": "forja.runDebug",
        "title": "Forja: Ejecutar en modo depuracion",
        "icon": "$(bug)"
      },
      {
        "command": "forja.runGUI",
        "title": "Forja: Ejecutar con interfaz nativa",
        "icon": "$(window)"
      },
      {
        "command": "forja.runRepl",
        "title": "Forja: Abrir REPL interactivo",
        "icon": "$(terminal)"
      },
      {
        "command": "forja.build",
        "title": "Forja: Compilar a bytecode",
        "icon": "$(gear)"
      },
      {
        "command": "forja.buildASM",
        "title": "Forja: Compilar a codigo maquina nativo",
        "icon": "$(chip)"
      },
      {
        "command": "forja.buildAndroid",
        "title": "Forja: Compilar para Android (multiplataforma)",
        "icon": "$(device-mobile)"
      },
      {
        "command": "forja.buildWASM",
        "title": "Forja: Compilar a WebAssembly",
        "icon": "$(globe)"
      },
      {
        "command": "forja.test",
        "title": "Forja: Ejecutar pruebas",
        "icon": "$(beaker)"
      },
      {
        "command": "forja.bench",
        "title": "Forja: Evaluar rendimiento",
        "icon": "$(dashboard)"
      },
      {
        "command": "forja.fmt",
        "title": "Forja: Formatear archivo",
        "icon": "$(paintcan)"
      },
      {
        "command": "forja.doc",
        "title": "Forja: Generar documentacion HTML",
        "icon": "$(book)"
      },
      {
        "command": "forja.diagram",
        "title": "Forja: Generar diagrama del programa",
        "icon": "$(graph)"
      },
      {
        "command": "forja.transpile",
        "title": "Forja: Transpilar a Rust",
        "icon": "$(symbol-file)"
      },
      {
        "command": "forja.hotReload",
        "title": "Forja: Recarga en caliente (recargar modulo activo)",
        "icon": "$(sync)"
      },
      {
        "command": "forja.hotRestart",
        "title": "Forja: Reinicio en caliente (reinicio rapido de interfaz)",
        "icon": "$(refresh)"
      },
      {
        "command": "forja.newProject",
        "title": "Forja: Nuevo proyecto...",
        "icon": "$(new-folder)"
      },
      {
        "command": "forja.selectVM",
        "title": "Forja: Seleccionar maquina virtual por omision",
        "icon": "$(vm)"
      },
      {
        "command": "forja.selectTarget",
        "title": "Forja: Seleccionar plataforma objetivo",
        "icon": "$(target)"
      },
      {
        "command": "forja.showOutput",
        "title": "Forja: Mostrar salida",
        "icon": "$(output)"
      },
      {
        "command": "forja.installToolchain",
        "title": "Forja: Instalar o verificar el entorno de compilacion",
        "icon": "$(package)"
      },
      {
        "command": "forja.openTutorial",
        "title": "Forja: Abrir tutorial interactivo",
        "icon": "$(book)"
      },
      {
        "command": "forja.openWasmPlayground",
        "title": "Forja: Abrir laboratorio WebAssembly",
        "icon": "$(globe)"
      },
      {
        "command": "forja.openDiagram",
        "title": "Forja: Abrir visor de diagramas",
        "icon": "$(graph)"
      },
      {
        "command": "forja.toggleHotReload",
        "title": "Forja: Activar o desactivar Recarga en Caliente",
        "icon": "$(sync-ignored)"
      },
      {
        "command": "forja.buildAndroid.arm64",
        "title": "Forja: Compilar para Android ARM64",
        "icon": "$(device-mobile)"
      },
      {
        "command": "forja.buildAndroid.x86_64",
        "title": "Forja: Compilar para Android x86_64",
        "icon": "$(device-mobile)"
      },
      {
        "command": "forja.buildAndroid.all",
        "title": "Forja: Compilar para Android (todos los objetivos)",
        "icon": "$(device-mobile)"
      },
      {
        "command": "forja.checkAndroidNDK",
        "title": "Forja: Verificar NDK Android",
        "icon": "$(check)"
      },
      {
        "command": "forja.deployAndroid",
        "title": "Forja: Desplegar en dispositivo Android",
        "icon": "$(plug)"
      },
      {
        "command": "forja.showAST",
        "title": "Forja: Mostrar AST del archivo activo",
        "icon": "$(symbol-struct)"
      },
      {
        "command": "forja.showBytecode",
        "title": "Forja: Mostrar bytecode generado",
        "icon": "$(symbol-ruler)"
      },
      {
        "command": "forja.openStdlib",
        "title": "Forja: Abrir archivo de la biblioteca",
        "icon": "$(library)"
      },
      {
        "command": "forja.openFile",
        "title": "Forja: Abrir archivo (uso interno)",
        "icon": "$(go-to-file)"
      },
      {
        "command": "forja.revealLine",
        "title": "Forja: Ir a linea (uso interno)",
        "icon": "$(go-to-file)"
      }
    ],
    "menus": {
      "editor/title": [
        {
          "when": "resourceLangId == forja",
          "command": "forja.run",
          "group": "navigation@1"
