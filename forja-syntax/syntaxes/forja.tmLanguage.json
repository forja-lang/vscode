{
  "$schema": "https://raw.githubusercontent.com/martinring/tmlanguage/master/tmlanguage.json",
  "name": "Forja",
  "scopeName": "source.forja",
  "fileTypes": [".fa"],
  "patterns": [
    { "include": "#comments" },
    { "include": "#strings" },
    { "include": "#characters" },
    { "include": "#numbers" },
    { "include": "#literals" },
    { "include": "#self-keyword" },
    { "include": "#keywords" },
    { "include": "#types" },
    { "include": "#builtins" },
    { "include": "#function-call" },
    { "include": "#uppercase-identifier" },
    { "include": "#operators" },
    { "include": "#punctuation" },
    { "include": "#identifiers" }
  ],
  "repository": {
    "comments": {
      "patterns": [
        {
          "name": "comment.line.documentation.forja",
          "match": "///.*$"
        },
        {
          "name": "comment.line.number-sign.forja",
          "match": "#.*$"
        },
        {
          "name": "comment.line.double-slash.forja",
          "match": "//.*$"
        },
        {
          "name": "comment.block.forja",
          "begin": "/\\*",
          "end": "\\*/"
        }
      ]
    },

    "strings": {
      "name": "string.quoted.double.forja",
      "begin": "\"",
      "end": "\"",
      "patterns": [
        {
          "name": "constant.character.escape.forja",
          "match": "\\\\(n|t|r|\"|\\\\|')"
        }
      ]
    },

    "characters": {
      "name": "constant.character.forja",
      "begin": "'",
      "end": "'",
      "patterns": [
        {
          "name": "constant.character.escape.forja",
          "match": "\\\\(n|t|r|\\\\|')"
        }
      ]
    },

    "self-keyword": {
      "name": "keyword.control.self.forja",
      "match": "\\beste\\b"
    },

    "keywords": {
      "patterns": [
        {
          "name": "keyword.control.forja",
          "match": "\\b(importar|variable|var|constante|const|mut|si|sino|mientras|para|repetir|funcion|fun|retornar|clase|constructor|nuevo|prestado|tipo|coincidir|caso|BD|externo|externa|hilo|canal|enviar|recibir|unir|rasgo|implementa|donde|seleccionar|tiempo|otro|requiere|asegura|siempre|resultado|anterior)\\b"
        }
      ]
    },

    "types": {
      "name": "storage.type.forja",
      "match": "\\b(Entero|Decimal|Texto|Booleano|Nulo|Exacto)\\b"
    },

    "literals": {
      "name": "constant.language.forja",
      "match": "\\b(verdadero|falso|nulo)\\b"
    },

    "numbers": {
      "patterns": [
        { "name": "constant.numeric.decimal.forja", "match": "\\b\\d+\\.\\d+\\b" },
        { "name": "constant.numeric.integer.forja", "match": "\\b\\d+\\b" }
      ]
    },

    "builtins": {
      "name": "support.function.forja",
      "match": "\\b(escribir|leer|asegurar|longitud|aleatorio|redondear|potencia|raiz|maximo|minimo|concatenar|insertar|eliminar|contiene|claves|valores|a_caracter|a_texto|a_entero|a_decimal|es_entero|es_texto|es_decimal|es_booleano|es_lista|es_mapa|es_nulo|es_arreglo|tiempo_actual|esperar|abrir_archivo|leer_archivo|escribir_archivo|crear_directorio|existe_archivo|conectar|consultar|ejecutar|cerrar|transaccion|guardar)\\b"
    },

    "function-call": {
      "match": "\\b([a-z_][a-zA-Z0-9_]*)(?=\\s*\\()",
      "captures": {
        "1": { "name": "entity.name.function.forja" }
      }
    },

    "uppercase-identifier": {
      "name": "support.class.forja",
      "match": "\\b[A-Z][a-zA-Z0-9_]*\\b"
    },

    "operators": {
      "name": "keyword.operator.forja",
      "match": "\\+\\+|--|==|!=|>=|<=|\\+=|-=|\\*=|/=|%=|&&|\\|\\||->|::|\\.\\.\\.|%|\\||&|\\+|-|\\*|/|>|<|!|="
    },

    "punctuation": {
      "patterns": [
        { "name": "punctuation.semicolon.forja", "match": ";" },
        { "name": "punctuation.comma.forja", "match": "," },
        { "name": "punctuation.colon.forja", "match": ":" },
        { "name": "punctuation.dot.forja", "match": "\\." },
        { "name": "punctuation.parenthesis.forja", "match": "[\\(\\)]" },
        { "name": "punctuation.brace.forja", "match": "[\\{\\}]" },
        { "name": "punctuation.bracket.forja", "match": "[\\[\\]]" },
        { "name": "punctuation.question.forja", "match": "\\?" },
        { "name": "punctuation.at.forja", "match": "@" }
      ]
    },

    "identifiers": {
      "name": "variable.other.readwrite.forja",
      "match": "\\b[a-z_][a-zA-Z0-9_]*\\b"
    }
  }
}
