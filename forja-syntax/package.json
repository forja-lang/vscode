          "group": "navigation@3"
        },
        {
          "when": "resourceLangId == forja",
          "command": "forja.runGUI",
          "group": "navigation@4"
        }
      ],
      "editor/context": [
        {
          "when": "resourceLangId == forja",
          "command": "forja.run",
          "group": "forja@1"
        },
        {
          "when": "resourceLangId == forja",
          "command": "forja.runFast",
