    "keybindings": [
      {
        "command": "forja.run",
        "key": "ctrl+alt+r",
        "when": "editorLangId == forja"
      },
      {
        "command": "forja.runFast",
        "key": "ctrl+alt+f",
        "when": "editorLangId == forja"
      },
      {
        "command": "forja.runDebug",
        "key": "ctrl+alt+d",
        "when": "editorLangId == forja"
      },
      {
        "command": "forja.fmt",
        "key": "ctrl+alt+l",
        "when": "editorLangId == forja"
      },
      {
        "command": "forja.runGUI",
        "key": "ctrl+alt+g",
        "when": "editorLangId == forja"
      },
      {
        "command": "forja.test",
        "key": "ctrl+alt+t",
        "when": "editorLangId == forja"
      },
      {
        "command": "forja.runRepl",
        "key": "ctrl+alt+p",
        "when": "editorLangId == forja"
      },
      {
        "command": "forja.hotReload",
        "key": "ctrl+alt+h",
        "when": "editorLangId == forja"
      },
      {
        "command": "forja.hotRestart",
        "key": "ctrl+shift+r",
        "when": "editorLangId == forja"
      },
      {
        "command": "forja.openTutorial",
        "key": "ctrl+alt+e",
        "when": "editorLangId == forja"
      }
    ],
    "configuration": {
      "title": "Forja",
      "properties": {
        "forja.lsp.path": {
          "type": "string",
          "default": "",
          "description": "Ruta al binario del LSP server forja-lsp. Vacío = auto-detect en PATH"
        },
        "forja.lsp.enabled": {
          "type": "boolean",
          "default": true,
          "description": "Habilitar/deshabilitar el servidor LSP"
        },
        "forja.defaultVM": {
          "type": "string",
          "default": "fastvm",
          "enum": [
            "fastvm",
            "vm",
            "jit"
          ],
          "enumDescriptions": [
            "ForjaFast (VM ultra-rápida, por defecto)",
            "ForjaVM clásica (estable y probada)",
            "JIT nativo con fallback a VM"
          ],
          "description": "Máquina virtual por defecto para ejecución"
        },
        "forja.defaultTarget": {
          "type": "string",
          "default": "native",
          "enum": [
            "native",
            "x86_64-pc-windows-msvc",
            "aarch64-linux-android",
            "x86_64-linux-android",
            "wasm32-unknown-unknown"
          ],
          "description": "Plataforma target por defecto para compilación"
        },
        "forja.buildArgs": {
          "type": "string",
          "default": "",
          "description": "Argumentos extra para el compilador Forja (CLI)"
        },
        "forja.terminal.preserveFocus": {
          "type": "boolean",
          "default": false,
          "description": "Mantener el foco en el editor al ejecutar comandos"
        },
        "forja.terminal.clearBeforeRun": {
          "type": "boolean",
          "default": false,
          "description": "Limpiar la terminal antes de ejecutar"
        },
        "forja.hotReload.enabled": {
          "type": "boolean",
          "default": true,
          "description": "Habilitar Hot Reload automático al guardar archivos .fa"
        },
        "forja.checkDiagnosticsOnSave": {
          "type": "boolean",
          "default": true,
          "description": "Ejecutar diagnóstico completo al guardar"
        }
      }
    },
    "taskDefinitions": [
      {
        "type": "forja",
        "required": [
          "task"
        ],
        "properties": {
          "task": {
            "type": "string",
            "description": "La tarea Forja a ejecutar: run, run-fast, run-jit, run-aot, build, test, bench, fmt, doc, diagram, transpile, build-asm, build-wasm, build-android"
          },
          "args": {
            "type": "string",
            "description": "Argumentos adicionales"
          }
        }
      }
    ],
    "snippets": [
      {
        "language": "forja",
        "path": "./snippets/forja.json"
      }
    ]
  },
  "scripts": {
    "compile": "tsc -p ./tsconfig.json",
    "watch": "tsc -watch -p ./tsconfig.json"
  },
  "devDependencies": {
    "@types/node": "^26.1.1",
    "@types/vscode": "^1.60.0",
    "@vscode/vsce": "^3.9.2",
    "typescript": "^5.0.0"
  },
  "dependencies": {
    "vscode-languageclient": "^8.0.0"
  }
}
